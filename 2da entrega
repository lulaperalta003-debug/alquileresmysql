   3) CREACION DE TABLAS


CREATE TABLE PROPIETARIO (
    id_propietario INT IDENTITY(1,1) PRIMARY KEY,
    nombre_apellido VARCHAR(100) NOT NULL,
    dni_cuit VARCHAR(20) NOT NULL UNIQUE,
    telefono VARCHAR(30),
    email VARCHAR(100),
    domicilio_fiscal VARCHAR(150)
);
GO

CREATE TABLE INQUILINO (
    id_inquilino INT IDENTITY(1,1) PRIMARY KEY,
    nombre_apellido VARCHAR(100) NOT NULL,
    dni_cuit VARCHAR(20) NOT NULL UNIQUE,
    telefono VARCHAR(30),
    email VARCHAR(100),
    domicilio_actual VARCHAR(150)
);
GO

CREATE TABLE INMUEBLE (
    id_inmueble INT IDENTITY(1,1) PRIMARY KEY,
    id_propietario INT NOT NULL,
    direccion VARCHAR(150) NOT NULL,
    barrio_ciudad VARCHAR(100),
    tipo_inmueble VARCHAR(50),
    estado VARCHAR(30) NOT NULL,
    CONSTRAINT FK_INMUEBLE_PROPIETARIO
        FOREIGN KEY (id_propietario) REFERENCES PROPIETARIO(id_propietario),
    CONSTRAINT CHK_INMUEBLE_ESTADO
        CHECK (estado IN ('Disponible', 'Alquilado', 'Mantenimiento'))
);
GO

CREATE TABLE CONTRATO (
    id_contrato INT IDENTITY(1,1) PRIMARY KEY,
    id_inmueble INT NOT NULL,
    id_inquilino INT NOT NULL,
    fecha_inicio DATE NOT NULL,
    fecha_fin DATE NOT NULL,
    moneda VARCHAR(10) NOT NULL,
    monto_inicial DECIMAL(12,2) NOT NULL,
    frecuencia_ajuste VARCHAR(20),
    indice_ajuste VARCHAR(30),
    estado_contrato VARCHAR(30) NOT NULL,
    CONSTRAINT FK_CONTRATO_INMUEBLE
        FOREIGN KEY (id_inmueble) REFERENCES INMUEBLE(id_inmueble),
    CONSTRAINT FK_CONTRATO_INQUILINO
        FOREIGN KEY (id_inquilino) REFERENCES INQUILINO(id_inquilino),
    CONSTRAINT CHK_CONTRATO_MONEDA
        CHECK (moneda IN ('ARS', 'USD')),
    CONSTRAINT CHK_CONTRATO_ESTADO
        CHECK (estado_contrato IN ('Vigente', 'Finalizado', 'Rescindido'))
);
GO

CREATE TABLE PAGO (
    id_pago INT IDENTITY(1,1) PRIMARY KEY,
    id_contrato INT NOT NULL,
    periodo DATE NOT NULL,
    fecha_vencimiento DATE NOT NULL,
    importe_facturado DECIMAL(12,2) NOT NULL,
    fecha_pago DATE NULL,
    importe_pagado DECIMAL(12,2) NULL,
    estado_pago VARCHAR(30) NOT NULL,
    medio_pago VARCHAR(30) NULL,
    CONSTRAINT FK_PAGO_CONTRATO
        FOREIGN KEY (id_contrato) REFERENCES CONTRATO(id_contrato),
    CONSTRAINT CHK_PAGO_ESTADO
        CHECK (estado_pago IN ('Pendiente', 'Pagado', 'Parcial', 'Vencido')),
    CONSTRAINT CHK_PAGO_MEDIO
        CHECK (medio_pago IN ('Transferencia', 'Efectivo', 'Deposito', 'Tarjeta') OR medio_pago IS NULL)
);
GO

CREATE TABLE AJUSTE_CONTRATO (
    id_ajuste INT IDENTITY(1,1) PRIMARY KEY,
    id_contrato INT NOT NULL,
    fecha_aplicacion DATE NOT NULL,
    indice_usado VARCHAR(30),
    porcentaje DECIMAL(8,2) NOT NULL,
    monto_nuevo DECIMAL(12,2) NOT NULL,
    CONSTRAINT FK_AJUSTE_CONTRATO
        FOREIGN KEY (id_contrato) REFERENCES CONTRATO(id_contrato)
);
GO

CREATE TABLE GARANTIA (
    id_garantia INT IDENTITY(1,1) PRIMARY KEY,
    id_contrato INT NOT NULL,
    tipo_garantia VARCHAR(50) NOT NULL,
    detalle VARCHAR(200),
    CONSTRAINT FK_GARANTIA_CONTRATO
        FOREIGN KEY (id_contrato) REFERENCES CONTRATO(id_contrato)
);
GO


