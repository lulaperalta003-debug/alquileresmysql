   5) VISTAS 
  
CREATE VIEW vw_contratos_vigentes
AS
SELECT
    c.id_contrato,
    i.direccion,
    i.barrio_ciudad,
    inq.nombre_apellido AS inquilino,
    c.fecha_inicio,
    c.fecha_fin,
    c.moneda,
    c.monto_inicial,
    c.frecuencia_ajuste,
    c.indice_ajuste,
    c.estado_contrato
FROM CONTRATO c
INNER JOIN INMUEBLE i
    ON c.id_inmueble = i.id_inmueble
INNER JOIN INQUILINO inq
    ON c.id_inquilino = inq.id_inquilino
WHERE c.estado_contrato = 'Vigente';
GO

CREATE VIEW vw_pagos_pendientes
AS
SELECT
    p.id_pago,
    p.id_contrato,
    p.periodo,
    p.fecha_vencimiento,
    p.importe_facturado,
    p.importe_pagado,
    p.estado_pago,
    p.medio_pago
FROM PAGO p
WHERE p.estado_pago IN ('Pendiente', 'Parcial');
GO

CREATE VIEW vw_resumen_ingresos_contrato
AS
SELECT
    c.id_contrato,
    i.direccion,
    inq.nombre_apellido AS inquilino,
    COUNT(p.id_pago) AS cantidad_pagos_registrados,
    SUM(ISNULL(p.importe_pagado, 0)) AS total_pagado,
    SUM(ISNULL(p.importe_facturado, 0)) AS total_facturado
FROM CONTRATO c
INNER JOIN INMUEBLE i
    ON c.id_inmueble = i.id_inmueble
INNER JOIN INQUILINO inq
    ON c.id_inquilino = inq.id_inquilino
LEFT JOIN PAGO p
    ON c.id_contrato = p.id_contrato
GROUP BY
    c.id_contrato,
    i.direccion,
    inq.nombre_apellido;
GO


   6) FUNCIONES (2)

CREATE FUNCTION fn_total_pagado_contrato (@id_contrato INT)
RETURNS DECIMAL(12,2)
AS
BEGIN
    DECLARE @total DECIMAL(12,2);

    SELECT @total = SUM(ISNULL(importe_pagado, 0))
    FROM PAGO
    WHERE id_contrato = @id_contrato;

    RETURN ISNULL(@total, 0);
END;
GO

CREATE FUNCTION fn_cantidad_pagos_contrato (@id_contrato INT)
RETURNS INT
AS
BEGIN
    DECLARE @cantidad INT;

    SELECT @cantidad = COUNT(*)
    FROM PAGO
    WHERE id_contrato = @id_contrato;

    RETURN ISNULL(@cantidad, 0);
END;
GO


   7) PROCEDIMIENTOS ALMACENADOS

/* Procedimiento 1: registrar un pago */
CREATE PROCEDURE sp_registrar_pago
    @id_contrato INT,
    @periodo DATE,
    @fecha_vencimiento DATE,
    @importe_facturado DECIMAL(12,2),
    @fecha_pago DATE = NULL,
    @importe_pagado DECIMAL(12,2) = NULL,
    @medio_pago VARCHAR(30) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    INSERT INTO PAGO
    (
        id_contrato,
        periodo,
        fecha_vencimiento,
        importe_facturado,
        fecha_pago,
        importe_pagado,
        estado_pago,
        medio_pago
    )
    VALUES
    (
        @id_contrato,
        @periodo,
        @fecha_vencimiento,
        @importe_facturado,
        @fecha_pago,
        @importe_pagado,
        CASE
            WHEN @importe_pagado IS NULL OR @importe_pagado = 0 THEN 'Pendiente'
            WHEN @importe_pagado < @importe_facturado THEN 'Parcial'
            ELSE 'Pagado'
        END,
        @medio_pago
    );
END;
GO

/* Procedimiento 2: obtener pagos de un contrato */
CREATE PROCEDURE sp_obtener_pagos_por_contrato
    @id_contrato INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        id_pago,
        id_contrato,
        periodo,
        fecha_vencimiento,
        importe_facturado,
        fecha_pago,
        importe_pagado,
        estado_pago,
        medio_pago
    FROM PAGO
    WHERE id_contrato = @id_contrato
    ORDER BY periodo;
END;
GO


   8) TRIGGERS 

CREATE TRIGGER trg_pago_estado_automatico
ON PAGO
AFTER INSERT
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE p
    SET estado_pago =
        CASE
            WHEN i.importe_pagado IS NULL OR i.importe_pagado = 0 THEN 'Pendiente'
            WHEN i.importe_pagado < i.importe_facturado THEN 'Parcial'
            ELSE 'Pagado'
        END
    FROM PAGO p
    INNER JOIN inserted i
        ON p.id_pago = i.id_pago;
END;
GO

CREATE TRIGGER trg_contrato_actualiza_inmueble
ON CONTRATO
AFTER INSERT
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE i
    SET estado = 'Alquilado'
    FROM INMUEBLE i
    INNER JOIN inserted ins
        ON i.id_inmueble = ins.id_inmueble;
END;
GO
